# Optional override for the AgroMind FastAPI backend URL (see `backend/`).
# Must be prefixed with EXPO_PUBLIC_ so Expo inlines it into the client bundle.
# Requires a cache-cleared restart to take effect: `npx expo start -c`.
#
# Default (no .env needed): `expo.extra.apiBaseUrl` from app.json, which
# currently points at the Railway production deployment.
EXPO_PUBLIC_API_BASE_URL=https://agromind2-production.up.railway.app

# Optional override for the Agro-Predict AI frost-prediction backend.
# Default (no .env needed): `expo.extra.agroPredictUrl` from app.json.
EXPO_PUBLIC_AGRO_PREDICT_URL=https://agro-predict-production.up.railway.app
