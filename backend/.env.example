# Optional — enables OpenAI-authored AI explanations.
# When unset the service falls back to a deterministic rule-based template.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Environment label exposed via /health.
ENVIRONMENT=development

# Sentinel Hub / Copernicus Data Space Ecosystem (CDSE) OAuth2 client.
# When unset, the /ndvi endpoint returns HTTP 503.
# Create a client at https://shapps.dataspace.copernicus.eu/dashboard/#/account/settings
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=

# Comma-separated list is NOT supported here (pydantic-settings reads JSON arrays).
# Example: CORS_ORIGINS=["https://app.example.com","http://localhost:8081"]
CORS_ORIGINS=["*"]
