# Optional — enables OpenAI-authored AI explanations.
# When unset the service falls back to a deterministic rule-based template.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Environment label exposed via /health.
ENVIRONMENT=development

# Comma-separated list is NOT supported here (pydantic-settings reads JSON arrays).
# Example: CORS_ORIGINS=["https://app.example.com","http://localhost:8081"]
CORS_ORIGINS=["*"]
