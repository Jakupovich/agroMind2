# SafeVision AI Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://safevision:safevision@db:5432/safevision
DATABASE_URL_SYNC=postgresql://safevision:safevision@db:5432/safevision

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM=alerts@safevision.ai

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Storage (S3)
S3_BUCKET=safevision-incidents
S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AI Service
AI_SERVICE_URL=http://ai-service:8001
YOLO_MODEL_PATH=models/yolov8n.pt
WEAPON_MODEL_PATH=models/weapon_detector.pt
ACTION_MODEL_PATH=models/action_classifier.pt

# Detection Thresholds
VIOLENCE_CONFIDENCE_THRESHOLD=0.65
WEAPON_CONFIDENCE_THRESHOLD=0.70
BULLYING_CONFIDENCE_THRESHOLD=0.60

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000
